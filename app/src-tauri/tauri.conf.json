{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coding Editor",
  "version": "../package.json",
  "identifier": "dev.joxiah.coding-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Coding Editor",
        "width": 800,
        "height": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' blob:; worker-src 'self' blob:; connect-src 'self' ws://localhost:1234 https://*.amazonaws.com https://snack.expo.dev https://*.expo.dev wss://*.expo.dev https://snackager.expo.io; img-src 'self' blob: data: https://*.amazonaws.com https://api.qrserver.com; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["resources/expo-template"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": ["$APPDATA/*", "$APPLOCALDATA/*"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5QzRGNTYxQzAzQjBCOEUKUldTT0N6dkFZZlhFaWZpUkVvR0hhcDlXVjRWQ2lnMEJrOTNrbjNUUmM1S3JkK0hGbGZ2WGxsTnUK",
      "endpoints": [
        "https://github.com/bjoxiah/coding-editor/releases/latest/download/latest.json"
      ]
    }
  }
}
