{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "coding-editor",
  "version": "../package.json",
  "identifier": "dev.joxiah.coding-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "coding-editor",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/expo-template"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": ["$APPDATA/*", "$APPLOCALDATA/*"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5QzRGNTYxQzAzQjBCOEUKUldTT0N6dkFZZlhFaWZpUkVvR0hhcDlXVjRWQ2lnMEJrOTNrbjNUUmM1S3JkK0hGbGZ2WGxsTnUK",
      "endpoints": [
        "https://github.com/bjoxiah/coding-editor/releases/latest/download/latest.json"
      ]
    }
  }
}
